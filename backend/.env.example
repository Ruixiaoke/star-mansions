# CORS 允许的前端来源
# 本地：Vite dev server；生产：GitHub Pages 域名（如 https://<user>.github.io）
ALLOWED_ORIGIN=http://localhost:5173

# 本地 Express dev server 端口
PORT=3000

# ── 存储：Supabase（PRD §15-a 选定）──
# 铁律 §0-3：真实值写进 backend/.env（已被 .gitignore 忽略）/ Vercel 项目 env，绝不提交。
# 生产在 Vercel 项目 Settings → Environment Variables 配同名变量。
# SECRET_KEY = service_role/secret（服务端专用，绝不下发前端）。未配置这两项时后端回落内存 mock。
SUPABASE_URL=
SUPABASE_SECRET_KEY=
