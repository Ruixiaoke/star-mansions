# ---------------------------------------------------------------------------
# 二十八星宿 App — .gitignore
# 栈：React 19 + TypeScript + Vite（前端）+ Vercel Functions（api/）+ Supabase
# 铁律 §0.3：密钥 / .env 绝不提交进 git
# ---------------------------------------------------------------------------

# --- 依赖 / Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- 构建产物 / Build output ---
dist/
dist-ssr/
build/
out/
*.local

# --- 密钥 / 环境变量（铁律：绝不提交）---
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# --- Vercel ---
.vercel

# --- Supabase 本地 ---
.branches
.temp
supabase/.temp/

# --- TypeScript / Vite 缓存 ---
*.tsbuildinfo
.vite/
node_modules/.vite/

# --- 测试 / 覆盖率 ---
coverage/
.nyc_output/

# --- 日志 ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- 编辑器 / IDE ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- 操作系统 / OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
